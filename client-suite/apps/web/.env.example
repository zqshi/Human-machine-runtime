# HMR 前端(client-suite/apps/web)环境变量说明
#
# 使用方式:
#   cd client-suite/apps/web && cp .env.example .env.local
#   npm run dev
#
# 所有前端变量必须以 VITE_ 前缀(否则不会暴露给客户端代码)。

# === WPS IM 通道(D11 守卫)===
# 是否启用 WPS IM 通道。投产默认不启用(决策 2026-06-25):
# WpsImAdapter 的 7 个方法(editMessage/redactMessage/createDmRoom/
# inviteToRoom/createGroupRoom/joinRoom/leaveRoom)尚未实现,
# 未启用时禁止实例化 WpsImAdapter,防止残留 wps-token 触发未实现方法。
# 启用前须先补齐 7 个方法(对照 WPS IM farmBaseUrl API)。
VITE_WPS_IM_ENABLED=false

# WPS IM 服务地址(仅 VITE_WPS_IM_ENABLED=true 时生效)
VITE_WPS_BASE_URL=http://localhost:3080

# === 认证 ===
# 登录认证模式:auto(默认,尝试 HMR 后端→Matrix 直连)/ hmr / matrix
VITE_AUTH_MODE=auto

# === 部署路径(可选)===
# 子路径部署时设置,如 /hmr/
# VITE_BASE_URL=/
