# HMR Server — 生产环境配置模板
# ⚠️  所有 secret/key 值必须替换为真实随机值
# 所有 service 地址为通用占位，部署时替换为企业自己的同类系统地址
# ⚠️  Gateway 段变量名须与 server/src/config/index.ts 的 gateway 块对齐
NODE_ENV=production
PORT=3002

# PostgreSQL
DATABASE_URL=postgresql://hmr:CHANGE_ME@postgres:5432/hmr

# ──── 认证 ────
# 选择 auth provider: local | oidc | platform-be-proxy | wps-oauth
# 公开版默认 local；企业接入自己的 SSO 时改 oidc 并填下方对应配置
AUTH_DEFAULT_PROVIDER=local
AUTH_AUTO_REGISTER=true
AUTH_ALLOW_LOCAL_FALLBACK=true

# Platform BE SSO（AUTH_DEFAULT_PROVIDER=platform-be-proxy 时必填，企业自有 IdP 地址）
PLATFORM_BE_API_URL=
PLATFORM_BE_AUTH_URL=
PLATFORM_BE_CLIENT_ID=
PLATFORM_BE_CLIENT_SECRET=
PLATFORM_BE_CALLBACK_URL=https://your-domain.example.com/api/auth/sso/callback

# OIDC（AUTH_DEFAULT_PROVIDER=oidc 时必填，企业自有 IdP）
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=https://your-domain.example.com/api/auth/sso/callback
OIDC_SCOPES=openid profile email

# WPS OAuth（AUTH_DEFAULT_PROVIDER=wps-oauth 时必填，企业自有 OAuth）
WPS_OAUTH_CLIENT_ID=
WPS_OAUTH_CLIENT_SECRET=
WPS_OAUTH_REDIRECT_URI=https://your-domain.example.com/api/auth/sso/callback
WPS_OAUTH_SCOPES=openid profile email

# Session
SESSION_SECRET=CHANGE_ME_RANDOM_64_CHARS
SESSION_COOKIE_NAME=hmr_session
SESSION_MAX_AGE_SEC=86400

# ──── 安全 ────
JWT_SECRET=CHANGE_ME_RANDOM_64_CHARS
JWT_EXPIRES_IN=8h
CREDENTIAL_ENCRYPTION_KEY=CHANGE_ME_RANDOM_32_CHARS
CREDENTIAL_LEASE_TTL_SEC=3600

# ──── Gateway — 指向企业内部同类服务 ────
# 留空则不连接，路由降级为仅返回本地数据。企业接入自己的同类系统时填写。
# 变量名须与 server/src/config/index.ts 的 gateway 块对齐
# （曾用旧名 CLAWHUB/PORTAL/XSPACE/CLAW_FARM，v1.2.1 已统一为下列标准名）。

# 技能 / Agent 市场（对应内部 clawhub）
MARKETPLACE_API_URL=
MARKETPLACE_HMAC_SECRET=
MARKETPLACE_API_KEY=

# Agent Profile + Token Usage（对应内部 portal）
PROFILE_SERVICE_API_URL=
PROFILE_SERVICE_API_TOKEN=

# AI Coding Workspace（对应内部 xspace）
WORKSPACE_BACKEND_API_URL=
WORKSPACE_BACKEND_APP_ID=
WORKSPACE_BACKEND_STREAM_TIMEOUT_MS=120000

# 实例管理 + IM 消息网关（对应内部 claw-farm）
CONTAINER_ORCHESTRATOR_API_URL=
CONTAINER_ORCHESTRATOR_WS_URL=
CONTAINER_ORCHESTRATOR_API_TOKEN=

# LiteLLM（模型代理网关，开源项目，企业自部署地址）
LITELLM_BASE_URL=http://litellm:4000
LITELLM_API_KEY=

# ──── Claude Agent SDK（claude-worker 沙箱执行，路径 A）────
# ANTHROPIC_API_KEY 配置后启用 claude-worker 主路径；留空则不注册 adapter，系统降级。
# 私有化（内网无 Anthropic 出口）：配 ANTHROPIC_BASE_URL 经企业代理转发
# （LiteLLM /v1/messages 或自建代理）。详见 docs/architecture/private-deployment-paths.md
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
# claude-worker 镜像（需先 bash scripts/build-claude-worker.sh 构建）
CLAUDE_WORKER_IMAGE=claude-worker:latest
CLAUDE_WORKER_TIMEOUT_MS=120000
CLAUDE_WORKSPACE_ROOT=/tmp/hmr-tasks
CLAUDE_DEFAULT_MODEL=claude-sonnet-4-6
CLAUDE_DEFAULT_MAX_TURNS=20
CLAUDE_DEFAULT_BUDGET_USD=5
# Agent 默认 LLM 模型别名（经 LiteLLM 路由，如 qwen-plus / deepseek-chat）。
# 留空则 AgentExecutor 走关键词降级；配置后走真实 LLM（路径 B 降级）。
AGENT_LLM_MODEL=

# ──── Gateway 调优 ────
GATEWAY_TIMEOUT_MS=10000
GATEWAY_READ_TIMEOUT_MS=5000
GATEWAY_WRITE_TIMEOUT_MS=10000
GATEWAY_RETRY_COUNT=3
GATEWAY_CB_THRESHOLD=5

# ──── Matrix（即时消息；企业自部署 Matrix 服务端，如 Synapse / Conduit）────
MATRIX_HOMESERVER_URL=http://matrix:6167
MATRIX_BOT_USER_ID=@hmr-bot:matrix.example.com
MATRIX_BOT_ACCESS_TOKEN=

# ──── WeKnora RAG（知识库；企业自部署或留空禁用）────
WEKNORA_ENABLED=
WEKNORA_API_URL=http://weknora:8088
WEKNORA_ADMIN_API_KEY=
WEKNORA_ENCRYPTION_KEY=

# ──── 上传 ────
UPLOAD_DIR=./uploads
UPLOAD_MAX_SIZE_MB=50

# ──── CORS ────
CORS_ORIGINS=https://your-domain.example.com

# ──── 限流 ────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ──── 数据库连接池 / 缓存 ────
DB_MAX_CONNECTIONS=20
# Redis（生产建议配置，供 rate-limit 等共享计数；留空则单实例内存）
REDIS_URL=

# ──── 邮件（生产发信；留空禁用）────
MAIL_HOST=
MAIL_PORT=25
MAIL_SECURE=false
MAIL_FROM=noreply@your-domain.example.com
MAIL_USER=
MAIL_PASS=

# ──── Mem0（记忆服务；留空禁用）────
MEM0_API_KEY=
MEM0_BASE_URL=https://api.mem0.ai

# ──── Workspace Backend Supabase（若 workspace-backend 接入走 Supabase 认证，可选）────
WORKSPACE_BACKEND_SUPABASE_URL=
WORKSPACE_BACKEND_SUPABASE_ANON_KEY=
WORKSPACE_BACKEND_SUPABASE_EMAIL=
WORKSPACE_BACKEND_SUPABASE_PASSWORD=

# ──── Seed（生产通常禁用）────
# 生产环境一般不跑全量 seed；如需 bootstrap 管理员用 production-bootstrap（读 HMR_SEED_ADMIN_PASSWORD）
SEED_PROFILE=showcase
# production profile 账号密码注入（仅当 SEED_PROFILE=production 且需 seed 账号时）
HMR_SEED_ADMIN_PASSWORD=
HMR_SEED_TENANT_ADMIN_PASSWORD=
HMR_SEED_OPS_PASSWORD=
HMR_SEED_AUDITOR_PASSWORD=
