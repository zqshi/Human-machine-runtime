# DCF Server Environment — 开发环境配置
# 复制为 .env 后按需修改
NODE_ENV=development
PORT=3002

# PostgreSQL
DATABASE_URL=postgresql://dcf:dcf@localhost:5432/dcf

# JWT — ⚠️ 生产环境务必更换
JWT_SECRET=dcf-dev-secret-change-in-production
JWT_EXPIRES_IN=24h
CREDENTIAL_ENCRYPTION_KEY=dcf-dev-encryption-key-change-me!!

# Auth
AUTH_DEFAULT_PROVIDER=local
# OIDC（留空则不启用）
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limit
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200

# Matrix Homeserver
MATRIX_HOMESERVER_URL=http://localhost:6167
MATRIX_BOT_USER_ID=@dcf-bot:localhost
MATRIX_BOT_ACCESS_TOKEN=

# LiteLLM
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=

# External Service Gateway（留空则不连接）
PLATFORM_BE_API_URL=
CLAWHUB_API_URL=
PORTAL_API_URL=
XSPACE_API_URL=
CLAW_FARM_API_URL=

# WeKnora Knowledge Base（留空则不启用）
WEKNORA_API_URL=http://localhost:8088
WEKNORA_ENABLED=
WEKNORA_ADMIN_API_KEY=
WEKNORA_ENCRYPTION_KEY=
