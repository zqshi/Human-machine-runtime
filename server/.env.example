# HMR Server Environment — 开发环境配置
# 复制为 .env 后按需修改。标 ⚠️ 的项在生产环境（NODE_ENV=production）必须替换为真实值，
# 否则启动时 validateProductionConfig() 会拒绝启动。
# 本文件覆盖 server/src/config/index.ts 读取的全部环境变量。

# ─────────────────────────────────────────────
# 基础
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=3002

# ─────────────────────────────────────────────
# 数据库（PostgreSQL，本地 docker-compose 映射宿主 5435 → 容器 5432）
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://hmr:hmr@localhost:5435/hmr
DB_MAX_CONNECTIONS=20

# Redis（可选）：配置后 rate-limit 等走共享计数；留空则 fallback 到进程内内存（单实例）
REDIS_URL=

# ─────────────────────────────────────────────
# 安全密钥 ⚠️ 生产必换
# ─────────────────────────────────────────────
JWT_SECRET=hmr-dev-secret-change-in-production
JWT_EXPIRES_IN=24h
CREDENTIAL_ENCRYPTION_KEY=hmr-dev-encryption-key-change-me!!
CREDENTIAL_LEASE_TTL_SEC=3600
SESSION_SECRET=hmr-session-secret-change-in-production
SESSION_MAX_AGE_SEC=86400
SESSION_COOKIE_NAME=hmr_session

# ─────────────────────────────────────────────
# 认证
# ─────────────────────────────────────────────
AUTH_DEFAULT_PROVIDER=local
AUTH_ALLOW_LOCAL_FALLBACK=true
AUTH_AUTO_REGISTER=true

# OIDC（留空则不启用）
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=
OIDC_SCOPES=openid profile email

# Platform-BE 代理认证（baseUrl 缺省回退到下方网关段的 PLATFORM_BE_API_URL）
PLATFORM_BE_AUTH_URL=
PLATFORM_BE_CLIENT_ID=
PLATFORM_BE_CLIENT_SECRET=
PLATFORM_BE_CALLBACK_URL=

# WPS OAuth（留空则不启用）
WPS_OAUTH_CLIENT_ID=
WPS_OAUTH_CLIENT_SECRET=
WPS_OAUTH_REDIRECT_URI=
WPS_OAUTH_SCOPES=openid profile email

# ─────────────────────────────────────────────
# CORS / 限流
# ─────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200

# ─────────────────────────────────────────────
# 文件上传
# ─────────────────────────────────────────────
UPLOAD_DIR=./uploads
UPLOAD_MAX_SIZE_MB=50

# ─────────────────────────────────────────────
# 邮件（留空则禁用发信）
# ─────────────────────────────────────────────
MAIL_HOST=
MAIL_PORT=25
MAIL_SECURE=false
MAIL_FROM=noreply@example.com
MAIL_USER=
MAIL_PASS=

# ─────────────────────────────────────────────
# Seed 数据
# ─────────────────────────────────────────────
# 可选值见 db/seed/profiles/（showcase / production / ...）
SEED_PROFILE=showcase
# production profile 账号密码注入（生产部署必填；留空时 seed 使用弱默认值并打印警告）
HMR_SEED_ADMIN_PASSWORD=
HMR_SEED_TENANT_ADMIN_PASSWORD=
HMR_SEED_OPS_PASSWORD=
HMR_SEED_AUDITOR_PASSWORD=

# Agent 默认 LLM 模型别名（经 LiteLLM 路由，如 qwen-plus / deepseek-chat / gpt-4o-mini）。
# 留空则 AgentExecutor 走关键词降级；配置后走真实 LLM。
AGENT_LLM_MODEL=

# ─────────────────────────────────────────────
# Matrix Homeserver
# ─────────────────────────────────────────────
MATRIX_HOMESERVER_URL=http://localhost:6167
MATRIX_BOT_USER_ID=@hmr-bot:localhost
MATRIX_BOT_ACCESS_TOKEN=

# ─────────────────────────────────────────────
# LiteLLM
# ─────────────────────────────────────────────
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=

# ─────────────────────────────────────────────
# 外部服务网关（留空则不连接）
# ─────────────────────────────────────────────
PLATFORM_BE_API_URL=
MARKETPLACE_API_URL=
MARKETPLACE_HMAC_SECRET=
MARKETPLACE_API_KEY=
PROFILE_SERVICE_API_URL=
PROFILE_SERVICE_API_TOKEN=
WORKSPACE_BACKEND_API_URL=
WORKSPACE_BACKEND_APP_ID=
WORKSPACE_BACKEND_SUPABASE_URL=
WORKSPACE_BACKEND_SUPABASE_ANON_KEY=
WORKSPACE_BACKEND_SUPABASE_EMAIL=
WORKSPACE_BACKEND_SUPABASE_PASSWORD=
WORKSPACE_BACKEND_STREAM_TIMEOUT_MS=120000
CONTAINER_ORCHESTRATOR_API_URL=
CONTAINER_ORCHESTRATOR_WS_URL=
CONTAINER_ORCHESTRATOR_API_TOKEN=
CLUSTER_INSTANCE_API_URL=
CLUSTER_INSTANCE_AUTH_TOKEN=

# 网关韧性参数
GATEWAY_RETRY_COUNT=3
GATEWAY_CB_THRESHOLD=5
GATEWAY_TIMEOUT_MS=10000
GATEWAY_READ_TIMEOUT_MS=5000
GATEWAY_WRITE_TIMEOUT_MS=10000

# ─────────────────────────────────────────────
# WeKnora 知识库（留空则不启用）
# ─────────────────────────────────────────────
WEKNORA_API_URL=http://localhost:8088
WEKNORA_ENABLED=
WEKNORA_ADMIN_API_KEY=
WEKNORA_ENCRYPTION_KEY=

# ─────────────────────────────────────────────
# Mem0（留空则不启用）
# ─────────────────────────────────────────────
MEM0_API_KEY=
MEM0_BASE_URL=https://api.mem0.ai
