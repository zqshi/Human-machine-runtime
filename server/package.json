{
  "name": "@hmr/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch --env-file .env src/app/index.ts",
    "build": "tsc -b",
    "start": "node dist/app/index.js",
    "type-check": "tsc --noEmit",
    "db:generate": "tsx node_modules/.bin/drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed/index.ts",
    "db:setup": "tsx src/db/migrate.ts && tsx src/db/seed/index.ts",
    "db:setup:prod": "NODE_ENV=production tsx src/db/migrate.ts && tsx src/db/seed/production-bootstrap.ts",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "adm-zip": "^0.5.17",
    "bcryptjs": "^3.0.0",
    "cron-parser": "^5.5.0",
    "drizzle-orm": "^0.44.0",
    "hono": "^4.7.0",
    "jose": "^6.2.3",
    "mem0ai": "^3.0.7",
    "nodemailer": "^9.0.0",
    "pino": "^10.3.1",
    "postgres": "^3.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/adm-zip": "^0.5.8",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.1",
    "drizzle-kit": "^0.30.0",
    "eslint": "^10.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.59.3",
    "vitest": "^3.1.0"
  }
}
